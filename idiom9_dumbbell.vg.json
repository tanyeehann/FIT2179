{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Consumer Price Index Growth by Region",
    "color": "#000000",
    "fontSize": 20,
    "subtitle": [
      "The line represents the total jump in living costs between selected years"
    ],
    "subtitleColor": "#1a1a1a",
    "subtitleFontSize": 14,
    "anchor": "start",
    "offset": 25
  },
  "width": 450,
  "height": 390,
  "data": {
    "url": "cpi_2d_state.csv",
    "format": {
      "type": "csv",
      "parse": {
        "date": "date:'%m/%d/%Y'"
      }
    }
  },
  "params": [
    {
      "name": "Start_Year",
      "value": 2015,
      "bind": {
        "input": "select",
        "options": [2011, 2012, 2013, 2014, 2015, 2016, 2017, 2018, 2019, 2020, 2021, 2022, 2023],
        "name": "Select Start Year: "
      }
    },
    {
      "name": "End_Year",
      "value": 2023,
      "bind": {
        "input": "select",
        "options": [2011, 2012, 2013, 2014, 2015, 2016, 2017, 2018, 2019, 2020, 2021, 2022, 2023],
        "name": "Select End Year: "
      }
    }
  ],
  "transform": [
    {
      "filter": "datum.state != 'Malaysia' && datum.state != 'Putrajaya'"
    },
    {
      "filter": "datum.division == 'overall'"
    },
    {
      "calculate": "year(datum.date)",
      "as": "Year_Num"
    },
    {
      "filter": "datum.Year_Num == Start_Year || datum.Year_Num == End_Year"
    },
    {
      "aggregate": [
        {
          "op": "mean",
          "field": "index",
          "as": "Avg_CPI"
        }
      ],
      "groupby": ["state", "Year_Num"]
    },
    {
      "calculate": "datum.Year_Num == Start_Year ? 'Start Year' : 'End Year'",
      "as": "Period"
    }
  ],
  "config": {
    "view": {
      "stroke": "transparent"
    },
    "axis": {
      "labelColor": "#000000",
      "titleColor": "#000000",
      "domain": false
    }
  },
  "layer": [
    {
      "mark": {
        "type": "line",
        "color": "#cfd8dc",
        "strokeWidth": 3
      },
      "encoding": {
        "x": {
          "field": "Avg_CPI",
          "type": "quantitative"
        },
        "y": {
          "field": "state",
          "type": "nominal",
          "title": "State / Territory",
          "sort": {"op": "max", "field": "Avg_CPI", "order": "descending"},
          "axis": {
            "grid": true,
            "gridDash": [2, 2],
            "gridColor": "#f5f5f5"
          }
        },
        "detail": {
          "field": "state",
          "type": "nominal"
        }
      }
    },
    {
      "mark": {
        "type": "circle",
        "opacity": 1,
        "size": 150
      },
      "encoding": {
        "x": {
          "field": "Avg_CPI",
          "type": "quantitative",
          "title": "Consumer Price Index (Base = 100)",
          "scale": {
            "zero": false
          },
          "axis": {
            "grid": true,
            "gridDash": [4, 4],
            "gridColor": "#e6e6e6"
          }
        },
        "y": {
          "field": "state",
          "type": "nominal"
        },
        "color": {
          "field": "Period",
          "type": "nominal",
          "title": "Time Period",
          "scale": {
            "domain": ["Start Year", "End Year"],
            "range": ["#90caf9", "#1565c0"]
          }
        },
        "tooltip": [
          {"field": "state", "type": "nominal", "title": "State / Territory"},
          {"field": "Year_Num", "type": "nominal", "title": "Selected Year"},
          {"field": "Avg_CPI", "type": "quantitative", "title": "Average Consumer Price Index", "format": ".2f"}
        ]
      }
    }
  ]
}