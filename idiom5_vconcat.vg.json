{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Rainfall Impact and Agricultural Yield Correlation by Region",
    "color": "#000000",
    "fontSize": 20,
    "subtitle": [
      "Comparing average regional rainfall against crop yields across Malaysian region"
    ],
    "subtitleColor": "#1a1a1a",
    "subtitleFontSize": 14,
    "anchor": "start",
    "offset": 25
  },
  "config": {
    "view": {
      "stroke": "transparent"
    },
    "concat": {
      "spacing": 15
    }
  },
  "params": [
    {
      "name": "Crop_Selection",
      "value": "Paddy",
      "bind": {
        "input": "select",
        "options": [
          "Cash crops", "Coconut", "Fruits", "Herbs", 
          "Industrial crops", "Paddy", "Spices", "Vegetables"
        ],
        "name": "Select Crop Category: "
      }
    }
  ],
  "vconcat": [
    {
      "width": 550,
      "height": 150,
      "data": {
        "url": "rainfall_state_clean.csv",
        "format": {
          "type": "csv"
        }
      },
      "transform": [
        {
          "filter": "datum.state != 'Malaysia'"
        }
      ],
      "mark": {
        "type": "bar",
        "color": "#1565c0",
        "cornerRadiusEnd": 3
      },
      "encoding": {
        "x": {
          "field": "state",
          "type": "nominal",
          "sort": "ascending",
          "axis": null
        },
        "y": {
          "field": "rfh",
          "aggregate": "mean",
          "type": "quantitative",
          "title": "Average Rainfall (millimeters)",
          "axis": {
            "grid": true,
            "gridDash": [4, 4],
            "gridColor": "#e6e6e6",
            "labelColor": "#000000",
            "titleColor": "#000000"
          }
        },
        "tooltip": [
          {"field": "state", "type": "nominal", "title": "Region"},
          {"field": "rfh", "aggregate": "mean", "type": "quantitative", "title": "Average Rainfall (millimeters)", "format": ".1f"}
        ]
      }
    },
    {
      "width": 550,
      "height": 250,
      "data": {
        "url": "crops_state.csv",
        "format": {
          "type": "csv"
        }
      },
      "transform": [
        {
          "filter": "datum.state != 'Malaysia'"
        },
        {
          "filter": "datum.crop_type != 'flower'"
        },
        {
          "calculate": "replace(datum.crop_type, '_', ' ')",
          "as": "Spaced_Crop"
        },
        {
          "calculate": "upper(slice(datum.Spaced_Crop, 0, 1)) + slice(datum.Spaced_Crop, 1)",
          "as": "Crop_Category"
        },
        {
          "filter": "datum.Crop_Category == Crop_Selection"
        },
        {
          "calculate": "datum.production / 1000",
          "as": "Production_Thousands"
        }
      ],
      "mark": {
        "type": "line",
        "color": "#2e7d32",
        "strokeWidth": 3,
        "point": {
          "filled": true,
          "fill": "#ffffff",
          "stroke": "#2e7d32",
          "strokeWidth": 2,
          "size": 70
        }
      },
      "encoding": {
        "x": {
          "field": "state",
          "type": "nominal",
          "sort": "ascending",
          "title": "Regions (States and Territories)",
          "axis": {
            "labelAngle": -45,
            "labelColor": "#000000",
            "titleColor": "#000000",
            "grid": false
          }
        },
        "y": {
          "field": "Production_Thousands",
          "aggregate": "mean",
          "type": "quantitative",
          "title": "Average Production (Thousands of Metric Tons)",
          "axis": {
            "grid": true,
            "gridDash": [4, 4],
            "gridColor": "#e6e6e6",
            "labelColor": "#000000",
            "titleColor": "#000000"
          }
        },
        "tooltip": [
          {"field": "state", "type": "nominal", "title": "Region"},
          {"field": "Crop_Category", "type": "nominal", "title": "Crop Category"},
          {"field": "Production_Thousands", "aggregate": "mean", "type": "quantitative", "title": "Average Production (Thousands of Metric Tons)", "format": ",.2f"}
        ]
      }
    }
  ]
}